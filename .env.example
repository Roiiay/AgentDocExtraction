# 模型 API 密钥
QWEN_API_KEY=your_qwen_api_key_here
GLM_API_KEY=your_glm_api_key_here

# 模型端点（可选，使用默认值即可）
# QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM_API_URL=https://open.bigmodel.cn/api/paas/v4

# 模型名称（可选）
# QWEN_MODEL=qwen-vl-flash
# GLM_MODEL=glm-4-flash

# 复杂度阈值（可选）
# COMPLEXITY_THRESHOLD_MEDIUM=0.25
# COMPLEXITY_THRESHOLD_COMPLEX=0.55

# YOLO 模型后端（可选）
# yolov11s = 使用 YOLOv11s-doclaynet 模型（默认）
# doclayout = 使用 DocLayout-YOLO 模型
# YOLO_MODEL_BACKEND=doclayout

# 审核设置（可选）
# MAX_REVIEW_ROUNDS=3
